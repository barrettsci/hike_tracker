# Copy this file to .env and fill in the values for local development.
# On shinyapps.io, set these in the dashboard → Environment Variables panel.

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# For shinyapps.io deployment only — leave blank for local dev (uses credentials.json).
# Generate with: base64 -w 0 credentials.json
GOOGLE_CREDENTIALS_JSON=
